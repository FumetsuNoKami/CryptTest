# Окружение: development | production
APP_ENV=development

# HTTP-сервер
SERVER_HOST=localhost
SERVER_PORT=8080
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=10s

# CoinGecko API
# Бесплатный план: https://www.coingecko.com/en/api
# API-ключ не обязателен для базовых запросов (до 30 req/min)
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=
COINGECKO_TIMEOUT=15s
COINGECKO_RATE_LIMIT=10
